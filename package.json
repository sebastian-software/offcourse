{
  "name": "offcourse",
  "version": "1.4.0",
  "description": "Download online courses for offline access – of course!",
  "type": "module",
  "bin": {
    "offcourse": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/offcourse.git"
  },
  "bugs": {
    "url": "https://github.com/sebastian-software/offcourse/issues"
  },
  "homepage": "https://sebastian-software.github.io/offcourse/",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:run && pnpm build",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm test:run && pnpm test:integration",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "release": "release-it",
    "prepublishOnly": "pnpm check",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write"
    ]
  },
  "keywords": [
    "course",
    "downloader",
    "offline",
    "cli",
    "e-learning",
    "video"
  ],
  "author": "Sebastian Software GmbH",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@sindresorhus/slugify": "^3.0.0",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^15.0.0",
    "conf": "^15.1.0",
    "delay": "^7.0.0",
    "execa": "^9.6.1",
    "hls-parser": "^0.16.1",
    "ky": "^2.0.2",
    "ora": "^9.4.1",
    "p-retry": "^8.0.0",
    "playwright": "^1.61.1",
    "turndown": "^7.2.4",
    "untildify": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^26.1.1",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "release-it": "^20.2.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
